    {
      "parameters": {
        "jsCode": "// pega todos os items do node anterior\nconst items = $input.all();\n\n// escolhe um índice aleatório\nconst randomIndex = Math.floor(Math.random() * items.length);\nconst randomItem = items[randomIndex];\n\n// tenta buscar o resultado do node \"Code in JavaScript\"\nconst speciesNode = $('Escolha aleatória da espécie').first().json.speciesName\n\n// retorna o resultado final\nreturn {\n  json: {\n    randomId: randomItem.json.id,\n    randomName: randomItem.json.name,\n    speciesName: speciesNode\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
