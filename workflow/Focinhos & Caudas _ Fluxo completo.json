      "parameters": {
        "jsCode": "let species;\nlet url;\n\nswitch (new Date().getDay()) {\n  case 0:\n    species = \"dog\";\n    url = \"https://api.thedogapi.com/v1/breeds\";\n    break;\n  case 1:\n    species = \"cat\";\n    url = \"https://api.thecatapi.com/v1/breeds\";\n    break;\n  case 2:\n    species = \"dog\";\n    url = \"https://api.thedogapi.com/v1/breeds\";\n    break;\n  case 3:\n    species = \"cat\";\n    url = \"https://api.thecatapi.com/v1/breeds\";\n    break;\n  case 4:\n    species = \"dog\";\n    url = \"https://api.thedogapi.com/v1/breeds\";\n    break;\n  case 5:\n    species = \"cat\";\n    url = \"https://api.thecatapi.com/v1/breeds\";\n    break;\n  case 6:\n    species = \"dog\";\n    url = \"https://api.thedogapi.com/v1/breeds\";\n    break;\n}\n\nreturn {\n  json: {\n    speciesName: species,\n    speciesUrl: url\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -608,
        -480
      ],
      "id": "08feafd1-cd53-405e-bd32-62d3080b38e1",
